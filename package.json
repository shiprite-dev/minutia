    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "serwist": "^9.5.10",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "postcss": "8.5.15",
      "ws": "8.21.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
