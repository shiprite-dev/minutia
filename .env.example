# =============================================================================
# Minutia Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Required: Supabase
# ---------------------------------------------------------------------------

# Your Supabase project URL (local: http://localhost:54321)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase anonymous/public key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres password for local Supabase (used by supabase start)
POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Required: Application
# ---------------------------------------------------------------------------

# Public URL of the app (used for share links, emails, OAuth callbacks)
SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional: AI Features
# ---------------------------------------------------------------------------

# API key for AI features (meeting summarization, etc). Leave empty to disable.
AI_API_KEY=

# AI model to use (default: claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Optional: Email (choose one provider)
# ---------------------------------------------------------------------------

# Option A: Resend (recommended for Cloud)
RESEND_API_KEY=

# Option B: SMTP (recommended for self-hosting)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# From address for outbound email
EMAIL_FROM=noreply@localhost

# ---------------------------------------------------------------------------
# Optional: Analytics & Monitoring (Cloud only)
# ---------------------------------------------------------------------------

# Plausible Analytics domain
PLAUSIBLE_DOMAIN=

# Sentry DSN for error tracking
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Optional: Authentication
# ---------------------------------------------------------------------------

# Google OAuth (for "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Optional: Billing (Cloud only)
# ---------------------------------------------------------------------------

# Stripe keys for subscription billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
