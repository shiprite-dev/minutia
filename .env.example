# =============================================================================
# Minutia Environment Variables
# Copy this file to .env and fill in the values.
#
# For Docker self-hosting, the required step is generating secrets:
#   1. Set JWT_SECRET to a random string (min 32 chars):
#        openssl rand -base64 48
#   2. Generate ANON_KEY and SERVICE_ROLE_KEY JWTs signed with that secret:
#        https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   3. Set MINUTIA_SETUP_TOKEN to a random setup password:
#        openssl rand -base64 32
#   4. Copy those values into the variables below, then run:
#        docker compose up -d
# =============================================================================

# ---------------------------------------------------------------------------
# Required: JWT Secret (used by all Supabase services)
# ---------------------------------------------------------------------------

# Generate a strong random string (min 32 chars):
#   openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# ---------------------------------------------------------------------------
# Required: Supabase API Keys
# ---------------------------------------------------------------------------

# These must be valid JWTs signed with JWT_SECRET above.
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#
# ANON_KEY: role=anon (safe for client-side, used as NEXT_PUBLIC_SUPABASE_ANON_KEY)
# SERVICE_ROLE_KEY: role=service_role (server-side only, bypasses RLS)
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# Also exposed as the client-side env var (mirrors ANON_KEY for the browser)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encrypts admin-managed runtime secrets stored in instance_config.
# If left blank, the app derives a key from SUPABASE_SERVICE_ROLE_KEY.
# Generate with: openssl rand -base64 32
INSTANCE_CONFIG_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Required: First-run setup token
# ---------------------------------------------------------------------------

# Required in production. Enter this token on /setup to create the first admin.
# Generate with: openssl rand -base64 32
MINUTIA_SETUP_TOKEN=replace-with-random-setup-token

# ---------------------------------------------------------------------------
# Required: Application URL
# ---------------------------------------------------------------------------

# Public URL of the app (used for share links, emails, OAuth callbacks)
SITE_URL=http://localhost:3000

# External API URL (used by GoTrue for auth redirects)
API_EXTERNAL_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Docker Compose: Database
# ---------------------------------------------------------------------------

# Change this in production!
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minutia

# ---------------------------------------------------------------------------
# Docker Compose: Port Mapping
# ---------------------------------------------------------------------------

# Web app port (the main UI)
WEB_PORT=3000

# Kong API gateway port (Supabase API endpoint)
KONG_HTTP_PORT=8000

# Postgres port (only exposed in development via docker-compose.override.yml)
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Optional: AI Features
# ---------------------------------------------------------------------------

# API key for AI features (smart briefs, auto-classification).
# Leave empty to disable AI features entirely.
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Optional: Auth Configuration
# ---------------------------------------------------------------------------

# Public self-signup is disabled by default. Keep this true for invite-only
# instances. To allow open self-signup, set this to false and set
# NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=true before building the web app.
DISABLE_SIGNUP=true
NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=false

# Optional login surfaces are hidden unless their backend path is configured.
NEXT_PUBLIC_ENABLE_MAGIC_LINK=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GUEST_LOGIN=false

# Auto-confirm emails (set to false if SMTP is configured)
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_SIGN_INS=false

# JWT token expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# Additional redirect URLs for auth links (comma-separated)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/accept-invite

# ---------------------------------------------------------------------------
# Optional: Email (SMTP)
# ---------------------------------------------------------------------------

# Configure SMTP to send invitation and password-reset emails.
# If left blank, GOTRUE_MAILER_AUTOCONFIRM should be true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@localhost
SMTP_SENDER_NAME=Minutia
EMAIL_FROM=noreply@localhost

# ---------------------------------------------------------------------------
# Optional: Email (Resend)
# ---------------------------------------------------------------------------

RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Optional: Realtime
# ---------------------------------------------------------------------------

# Secret key base for Realtime service (Elixir Phoenix).
# Generate with: openssl rand -base64 48
# A default is provided so Docker Compose works out of the box.
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# ---------------------------------------------------------------------------
# Optional: Google Sign-In (OAuth provider for login)
# ---------------------------------------------------------------------------

# Create an OAuth 2.0 Web Client in Google Cloud Console.
# Set the authorized redirect URI to:
#   http://localhost:8000/auth/v1/callback  (self-hosted)
#   https://<project>.supabase.co/auth/v1/callback  (managed Supabase)
# These credentials are used by GoTrue for authentication.
ENABLE_GOOGLE_AUTH=false
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Optional: Google Calendar Integration
# ---------------------------------------------------------------------------

# Separate OAuth 2.0 credentials for Google Calendar read access.
# This uses a different redirect URI from the sign-in flow above.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Encryption key for Google OAuth tokens stored in DB.
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=
