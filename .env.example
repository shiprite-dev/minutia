# =============================================================================
# Minutia Environment Variables
# Copy this file to .env and fill in the values.
#
# For Docker self-hosting, the required step is generating secrets:
#   1. Set JWT_SECRET to a random string (min 32 chars):
#        openssl rand -base64 48
#   2. Generate ANON_KEY and SERVICE_ROLE_KEY JWTs signed with that secret:
#        https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   3. Set MINUTIA_SETUP_TOKEN to a random setup password:
#        openssl rand -base64 32
#   4. Copy those values into the variables below, then run:
#        docker compose up -d
# =============================================================================

# ---------------------------------------------------------------------------
# Required: JWT Secret (used by all Supabase services)
# ---------------------------------------------------------------------------

# Generate a strong random string (min 32 chars):
#   openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# ---------------------------------------------------------------------------
# Required: Supabase API Keys
# ---------------------------------------------------------------------------

# These must be valid JWTs signed with JWT_SECRET above.
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#
# ANON_KEY: role=anon (safe for client-side, used as NEXT_PUBLIC_SUPABASE_ANON_KEY)
# SERVICE_ROLE_KEY: role=service_role (server-side only, bypasses RLS)
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# Also exposed as the client-side env var (mirrors ANON_KEY for the browser)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encrypts admin-managed runtime secrets stored in instance_config.
# If left blank, the app derives a key from SUPABASE_SERVICE_ROLE_KEY.
# Generate with: openssl rand -base64 32
INSTANCE_CONFIG_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Required: First-run setup token
# ---------------------------------------------------------------------------

# Required in production. Enter this token on /setup to create the first admin.
# Generate with: openssl rand -base64 32
MINUTIA_SETUP_TOKEN=replace-with-random-setup-token

# ---------------------------------------------------------------------------
# Required: Application URL
# ---------------------------------------------------------------------------

# Public URL of the app (used for share links, emails, OAuth callbacks)
SITE_URL=http://localhost:3000

# External API URL (used by GoTrue for auth redirects)
API_EXTERNAL_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional: Trusted Reverse Proxy
# ---------------------------------------------------------------------------

# Set to "cloudflare" when the instance sits behind Cloudflare (orange-cloud
# proxy or a Cloudflare Tunnel). The middleware will then read the real client
# IP from the CF-Connecting-IP header (which Cloudflare sets) for accurate rate
# limiting. Leave blank for direct connections or any other reverse proxy setup.
TRUSTED_PROXY=

# ---------------------------------------------------------------------------
# Docker Compose: Database
# ---------------------------------------------------------------------------

# Change this in production!
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minutia

# ---------------------------------------------------------------------------
# Docker Compose: Port Mapping
# ---------------------------------------------------------------------------

# Web app port (the main UI)
WEB_PORT=3000

# Kong API gateway port (Supabase API endpoint)
KONG_HTTP_PORT=8000

# Postgres port (only exposed in development via docker-compose.override.yml)
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Optional: AI Features
# ---------------------------------------------------------------------------

# OpenRouter API key for AI features (notes enhancement, smart briefs, auto-classification).
# Leave empty to disable AI features entirely.
OPENROUTER_API_KEY=
AI_API_KEY=
AI_MODEL=google/gemini-3.1-flash-lite
# Cheaper, widely available model the AI falls back to if AI_MODEL fails or is unavailable.
AI_MODEL_FALLBACK=google/gemini-3.1-flash-lite

# ---------------------------------------------------------------------------
# Optional: Per-account feature gating
# ---------------------------------------------------------------------------

# Leave unset (or "false") and every feature is available to all users. Set to
# "true" only if you operate per-account feature gating backed by the
# profiles.has_full_access column.
NEXT_PUBLIC_FEATURE_GATING=false

# ---------------------------------------------------------------------------
# Optional: Transcription (speech-to-text for recorded meetings, )
# ---------------------------------------------------------------------------

# Primary speech-to-text provider: groq | openrouter | deepgram | local.
# groq is free-tier and OpenAI-compatible; OpenRouter is always tried as a
# fallback when its key is set. Leave keys empty to disable transcription.
TRANSCRIPTION_PROVIDER=groq
# Groq API key (primary, free tier): https://console.groq.com
GROQ_API_KEY=
# The OpenRouter fallback reuses OPENROUTER_API_KEY (above). Optionally override
# its STT model or endpoint (OpenRouter's base64-JSON transcription API):
# OPENROUTER_STT_MODEL=openai/whisper-large-v3
# OPENROUTER_STT_URL=https://openrouter.ai/api/v1/audio/transcriptions
# Diarizing STT primary (cloud lane). Leave blank to fall back to Groq (no diarization).
ASSEMBLYAI_API_KEY=
# Reserved for the deepgram provider (not yet wired): https://console.deepgram.com
DEEPGRAM_API_KEY=
# Keyless self-host diarization: URL of the optional WhisperX+pyannote sidecar.
# When set and TRANSCRIPTION_PROVIDER=local, audio never leaves the instance.
TRANSCRIPTION_LOCAL_URL=

# ---------------------------------------------------------------------------
# Optional: Auth Configuration
# ---------------------------------------------------------------------------

# Public self-signup is gated by NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP. When true,
# a dedicated /signup screen is reachable and the login page shows a prominent
# "Create an account" link; when false (invite-only), /signup redirects to
# /login and the login page shows the invite-request box instead.
# GoTrue must also allow signups (DISABLE_SIGNUP=false) for the API to accept
# them. New signups must verify their email before logging in
# (ENABLE_EMAIL_AUTOCONFIRM=false). Configure SMTP (below) so the verification
# email can be delivered. To revert to invite-only, set DISABLE_SIGNUP=true and
# NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=false.
DISABLE_SIGNUP=true
NEXT_PUBLIC_ENABLE_PUBLIC_SIGNUP=false

# Optional login surfaces are hidden unless their backend path is configured.
NEXT_PUBLIC_ENABLE_MAGIC_LINK=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GUEST_LOGIN=false

# Auto-confirm emails. Set to true only if SMTP is NOT configured (dev/CI).
# In production, leave false so signups verify their email before app access.
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_SIGN_INS=false

# JWT token expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# Auth redirect allow-list (comma-separated). GoTrue may only bounce a verify
# link to these URLs. /auth/callback exchanges the code for a session (signup
# confirmation, magic link, OAuth); /accept-invite handles invites;
# /reset-password handles recovery. Keep all entries same-origin.
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback,http://localhost:3000/accept-invite,http://localhost:3000/reset-password

# ---------------------------------------------------------------------------
# Optional: Email (SMTP)
# ---------------------------------------------------------------------------

# Configure SMTP to send invitation and password-reset emails.
# If left blank, set ENABLE_EMAIL_AUTOCONFIRM=true so signups are confirmed
# without an email round-trip (otherwise new accounts can never confirm).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@localhost
SMTP_SENDER_NAME=Minutia
EMAIL_FROM=noreply@localhost

# ---------------------------------------------------------------------------
# Optional: Email (Resend)
# ---------------------------------------------------------------------------

RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Optional: Realtime
# ---------------------------------------------------------------------------

# Secret key base for Realtime service (Elixir Phoenix).
# Generate with: openssl rand -base64 48
# A default is provided so Docker Compose works out of the box.
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# ---------------------------------------------------------------------------
# Optional: Google Sign-In (OAuth provider for login)
# ---------------------------------------------------------------------------

# Create an OAuth 2.0 Web Client in Google Cloud Console.
# Set the authorized redirect URI to:
#   http://localhost:8000/auth/v1/callback  (self-hosted)
#   https://<project>.supabase.co/auth/v1/callback  (managed Supabase)
# These credentials are used by GoTrue for authentication.
ENABLE_GOOGLE_AUTH=false
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Optional: Google Calendar Integration
# ---------------------------------------------------------------------------

# Separate OAuth 2.0 credentials for Google Calendar read access.
# This uses a different redirect URI from the sign-in flow above.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Required for Google Calendar push notifications in production.
# Google requires this endpoint to be HTTPS with a valid certificate.
GOOGLE_CALENDAR_WEBHOOK_URL=https://your-domain.example/api/calendar/webhook

# Encryption key for Google OAuth tokens stored in DB.
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=
